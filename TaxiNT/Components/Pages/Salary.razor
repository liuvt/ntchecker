@page "/salary/{userId}/{date?}"
@layout EmptyMainLayout

@using SalaryModel = TaxiNT.Libraries.Models.Salary
@using SalaryDetailsModel = TaxiNT.Libraries.Models.SalaryDetails
@using TaxiNT.Libraries.Entities
@using TaxiNT.Libraries.Extensions
@using static TaxiNT.Libraries.Extensions.FormatCurrencyExtension

<SeoHeaderComponent Title="Bảng kê v1.2"
                    Description="@($"Kiểm tra bảng kê tài xế {userId}")" Ads="false" />

<div class="mx-auto max-w-7xl px-1 sm:px-6 md:px-4 lg:px-8">
    <div class="mb-4 text-center">
        <p class="flex items-center justify-center gap-2 text-xl font-semibold text-green-600 md:text-2xl">
            <img width="32" src="../icons/checkerdetail/bill-v2.png" alt="Đang tải..." />
            BẢNG KÊ THÁNG
        </p>
        <p class="text-sm text-gray-600 italic">@salary.salaryDate</p>
    </div>

    <div class="justify-center rounded-lg bg-white p-1 shadow md:p-6">
        <div class="mb-6 flex flex-wrap justify-between">
            <div class="text-green-600">
                <p class="font-semibold">@salary.userId</p>
                <p>TỔNG DOANH THU: @salary.revenue.ltvVNDCurrency()</p>
                <p>TỔNG SỐ CA: @salary.businessDays</p>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Nội dung</th>
                        <th class="px-4 py-2 text-right text-sm font-medium text-gray-500">Số tiền</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white">
                    <tr>
                        <td class="px-4 py-3">
                            <h6 class="font-semibold text-green-600">TẠM TÍNH</h6>
                            <p class="text-xs text-gray-500 italic">
                                Bảng kê tạm tính theo doanh thu tháng
                            </p>
                        </td>
                        <td class="px-4 py-3 text-right font-semibold text-green-600">@salary.salaryBase.ltvVNDCurrency()</td>
                    </tr>

                    @foreach (var item in Deductions.Where(x => x.Amount != "0"))
                    {
                        <tr>
                            <td class="px-4 py-3">
                                <span class="font-medium text-gray-700">@item.Name (-)</span>
                                <p class="text-xs text-gray-500 italic">@item.NameAlias</p>
                            </td>
                            <td class="px-4 py-3 text-right">@item.Amount</td>
                        </tr>
                    }

                    <tr>
                        <td class="px-4 py-3">
                            <h6 class="font-semibold text-red-600">TỔNG TRỪ</h6>
                        </td>
                        <td class="px-4 py-3 text-right font-semibold text-red-600">@salary.deductTotal.ltvVNDCurrency()</td>
                    </tr>

                    <tr>
                        <td class="px-4 py-3">
                            <h5 class="text-lg font-bold text-green-700">THỰC NHẬN</h5>
                        </td>
                        <td class="px-4 py-3 text-right text-lg font-bold text-green-700">@salary.salaryNet.ltvVNDCurrency()</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="mt-5">
            <div class="text-green-600">
                <p>CHI TIẾT DOANH THU NGÀY</p>
                <p>
                    Loại:
                    @if (salary.salaryType == "Ăn chia tháng")
                    {
                        <span>Ăn chia tháng</span>
                    }
                    else if (salary.salaryType == "Ăn chia ngày")
                    {
                        <span>Ăn chia ngày</span>
                    }
                    else
                    {
                        <span>@salary.salaryType</span>
                    }
                </p>
            </div>
            <!-- Bảng chuẩn -->
            <div class="overflow-x-auto">
                @if (((salary.salaryType != "Ăn chia tháng")))
                {
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-700">Ngày</th>
                                <th class="px-4 py-3 text-right text-sm font-medium text-gray-700">Doanh thu</th>
                                <th class="px-4 py-3 text-right text-sm font-medium text-gray-700">Sau mức ăn chia</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            @foreach (var item in salaryDetails)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm whitespace-nowrap">@item.daterevenues</td>
                                    <td class="px-4 py-3 text-right text-sm whitespace-nowrap text-green-700">@item.revenue.ltvVNDCurrency()</td>
                                    <td class="px-4 py-3 text-right text-sm whitespace-nowrap text-green-700">@item.salaryBase.ltvVNDCurrency()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }else{
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-sm font-medium text-gray-700">Ngày</th>
                            <th class="px-4 py-3 text-right text-sm font-medium text-gray-700">Doanh thu</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 bg-white">
                        @foreach (var item in salaryDetails)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-3 text-sm whitespace-nowrap">@item.daterevenues</td>
                                <td class="px-4 py-3 text-right text-sm whitespace-nowrap text-green-700">@item.revenue.ltvVNDCurrency()</td>
                            </tr>
                        }
                    </tbody>
                </table>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string userId { get; set; } = default!;

    /// <summary>
    /// Tháng cần xem chi tiết (ví dụ: "05/2025"). 
    /// Nếu null → lấy bản ghi mới nhất.
    /// </summary>
    [Parameter]
    public string? Date { get; set; }

    [Inject]
    protected ISalaryService salaryService { get; set; } = default!;

    protected SalaryModel salary { get; set; } = new();
    protected List<SalaryDetailsModel> salaryDetails { get; set; } = new();
    protected List<DeductionItem> Deductions { get; set; } = new();

    protected string errorMessage { get; set; } = string.Empty;
    protected bool isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Gọi API duy nhất để lấy cả Salary + Details
            var fullData = await salaryService.GetSalaryFull(userId, Date);

            salary = fullData.Salary;
            salaryDetails = fullData.Details;
            Console.WriteLine($"Error: {salary.userId}");

            // Xây dựng danh sách các khoản trừ (dùng dữ liệu từ salary)
            await BuildDeductionsAsync(salary);

            isLoaded = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Error: {errorMessage}");
            isLoaded = false;
        }
    }

    /// <summary>
    /// Xây dựng danh sách các khoản trừ từ dữ liệu Salary
    /// </summary>
    private Task BuildDeductionsAsync(SalaryModel salaryData)
    {
        Deductions.Clear();

        Deductions.AddRange(new List<DeductionItem>
        {
            new() { Name = "Ký quỹ", NameAlias = "Tiền ký quỹ với công ty", Amount = salaryData.deductForDeposit.ltvVNDCurrency() },
            new() { Name = "Tạm ứng", NameAlias = "Tạm ứng tiền công ty", Amount = salaryData.deductForSalaryAdvance.ltvVNDCurrency() },
            new() { Name = "Âm ăn chia", NameAlias = "Trừ tiền âm ăn chia tháng trước (xe công ty)", Amount = salaryData.deductForNegativeSalary.ltvVNDCurrency() },
            new() { Name = "Biên bản", NameAlias = "Trừ vi phạm biên bản của tài xế", Amount = salaryData.deductForViolationReport.ltvVNDCurrency() },
            new() { Name = "Nợ sửa chữa", NameAlias = "Chi phí phát sinh liên quan đến việc bảo trì, sửa chữa", Amount = salaryData.no_sua_chua.ltvVNDCurrency() },
            new() { Name = "Hao mòn vỏ xe", NameAlias = "Hao mòn vỏ xe", Amount = salaryData.haomon_voxe.ltvVNDCurrency() },
            new() { Name = "Sạt pin", NameAlias = "Trừ sạt pin đối với ăn chia ngày", Amount = salaryData.deductForCharging.ltvVNDCurrency() },
            new() { Name = "Phạt sạc", NameAlias = "Sạc pin đầy nhưng không rút sạt", Amount = salaryData.deductForChargingPenalty.ltvVNDCurrency() },
            new() { Name = "VETC", NameAlias = "Qua trạm thu phí", Amount = salaryData.deductForTollPayment.ltvVNDCurrency() },
            new() { Name = "BHXH", NameAlias = "BHXH", Amount = salaryData.deductForSocialInsurance.ltvVNDCurrency() },
            new() { Name = "Âm ăn chia (xe thương quyền)", NameAlias = "Trừ tiền âm ăn chia tháng trước (xe thương quyền)", Amount = salaryData.deductForNegativeSalaryPartner.ltvVNDCurrency() },
            new() { Name = "TNCN", NameAlias = "TNCN", Amount = salaryData.deductForPIT.ltvVNDCurrency() },
            new() { Name = "Trừ khác", NameAlias = salaryData.noteDeductOrder, Amount = salaryData.deductForOrder.ltvVNDCurrency() }
        });

        return Task.CompletedTask;
    }
}
