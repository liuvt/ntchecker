@page "/salary/{userId}"
@page "/salary/{userId}/{date}"
@inject NavigationManager NavigationManager
@layout EmptyMainLayout

<SeoHeaderComponent Title="Bảng kê v1.2"
                    Description="@($"Bảng kê tài xế {keyword}. Tháng {date}")" Ads="false" />

<script>
    function changeSalaryMonth(selectedMonth) {
        if (!selectedMonth) return;

        const userId = '@Uri.EscapeDataString(userId ?? string.Empty)';

        window.location.href = `/salary/${userId}/${selectedMonth}`;
    }
</script>

<div class="mx-auto max-w-4xl bg-gray-50 px-3 py-6">
    <div class="mb-6 text-center">
        <div class="flex items-center justify-center gap-3">
            <svg class="h-8 w-8 text-green-600"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor">
                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z" />
            </svg>

            <h1 class="text-2xl font-extrabold text-green-700 uppercase">
                Bảng kê
            </h1>
        </div>

        <div class="relative z-10 mt-2 inline-flex h-8 w-[110px] items-center justify-center gap-2 overflow-hidden rounded-full border border-red-100 bg-red-50 px-3 shadow-sm">
            <span class="pointer-events-none text-sm font-bold whitespace-nowrap text-red-500">
                @displayMonth
            </span>
            <input id="monthPicker"
                   type="month"
                   cursor="handle"
                   value="@currentMonthValue"
                   max="@maxMonthAllowed"
                   class="absolute inset-0 z-10 h-full w-full cursor-pointer opacity-0"
                   onchange="changeSalaryMonth(this.value)" />

            <span class="pointer-events-none text-sm">📅</span>

        </div>
    </div>

    @if (!isLoaded && string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-xl border border-gray-200 bg-white p-8 text-center shadow-sm">
            <div class="mx-auto h-8 w-8 animate-spin rounded-full border-4 border-gray-200 border-t-green-600"></div>
            <p class="mt-3 text-sm text-gray-500">Đang tải Bảng kê...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-xl border border-red-200 bg-red-50 p-5 text-center shadow-sm">
            <p class="font-semibold text-red-700">Không thể tải Bảng kê</p>
            <p class="mt-1 text-sm text-red-600">@errorMessage</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            <!-- Thông tin tổng quan -->
            <section class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="border-b border-green-100 bg-green-50 px-4 py-4">
                    <div class="grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
                        <!-- Thông tin tài xế -->
                        <div class="min-w-0">
                            <p class="font-semibold tracking-wide text-[11px] text-gray-500 uppercase">
                                Mã tài xế
                            </p>

                            <p class="mt-1 text-base leading-snug font-extrabold break-words text-green-700 sm:text-lg">
                                @salary.userId
                            </p>
                        </div>

                        <!-- Khu vực -->
                        <div class="w-full rounded-lg border border-green-200 bg-white px-3 py-2 sm:w-auto sm:min-w-[120px] sm:text-right">
                            <p class="text-[11px] text-gray-500">
                                Khu vực
                            </p>

                            <p class="mt-0.5 font-semibold text-gray-800">
                                @(string.IsNullOrWhiteSpace(salary.area) ? "—" : salary.area)
                            </p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-px bg-gray-200 sm:grid-cols-4">
                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Tổng doanh thu</p>
                        <p class="mt-1 font-bold text-green-700">@salary.revenue.ltvVNDCurrency()</p>
                    </div>

                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Tổng số ca</p>
                        <p class="mt-1 font-bold text-gray-800">@salary.businessDays</p>
                    </div>

                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Số cuốc</p>
                        <p class="mt-1 font-bold text-gray-800">@salary.tripsTotal</p>
                    </div>

                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Hình thức</p>
                        <p class="mt-1 font-bold text-gray-800">@FormatSalaryType(salary.salaryType)</p>
                    </div>
                </div>
            </section>

            <!-- Tổng hợp lương -->
            <section class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="border-b border-gray-200 px-4 py-3">
                    <h2 class="font-bold text-gray-800 uppercase">Tổng hợp bảng kê</h2>
                </div>

                <div class="divide-y divide-gray-100">
                    <div class="flex items-center justify-between gap-4 px-4 py-4">
                        <div>
                            <p class="font-semibold text-green-700">Tạm tính</p>
                            <p class="text-xs text-gray-500 italic">Ăn chia cơ bản hoặc số tiền sau mức ăn chia</p>
                        </div>
                        <p class="text-right font-bold whitespace-nowrap text-green-700">@salary.salaryBase.ltvVNDCurrency()</p>
                    </div>

                    @if (deductDetails.Count > 0)
                    {
                        @foreach (var item in deductDetails.Where(x => x.Amount != 0))
                        {
                            <div class="flex items-start justify-between gap-4 px-4 py-3">
                                <div class="min-w-0">
                                    <p class="font-medium text-gray-700">@item.Name <span class="text-red-500">(-)</span></p>

                                    @if (!string.IsNullOrWhiteSpace(item.Note))
                                    {
                                        <p class="mt-0.5 text-xs text-gray-500 italic">@item.Note</p>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(item.Code))
                                    {
                                        <p class="mt-0.5 text-xs text-gray-400 italic">@item.Code</p>
                                    }
                                </div>

                                <p class="text-right font-medium whitespace-nowrap text-gray-800">@item.Amount.ltvVNDCurrency()</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="px-4 py-4 text-center text-sm text-gray-500">
                            Không có khoản trừ.
                        </div>
                    }

                    <div class="flex items-center justify-between gap-4 bg-red-50 px-4 py-4">
                        <p class="font-bold text-red-600 uppercase">Tổng trừ</p>
                        <p class="text-right font-bold whitespace-nowrap text-red-600">@salary.deductTotal.ltvVNDCurrency()</p>
                    </div>

                    <div class="flex items-center justify-between gap-4 bg-green-50 px-4 py-5">
                        <div>
                            <p class="text-lg font-extrabold text-green-700 uppercase">Thực nhận</p>
                            <p class="text-xs text-green-600">Số tiền sau khi trừ các khoản phát sinh</p>
                        </div>
                        <p class="text-xl font-extrabold whitespace-nowrap text-green-700">@salary.salaryNet.ltvVNDCurrency()</p>
                    </div>
                </div>
            </section>

            <!-- Chi tiết doanh thu -->
            <section class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="flex items-center justify-between gap-3 border-b border-gray-200 px-4 py-3">
                    <div class="min-w-0">
                        <h2 class="font-bold text-gray-800 uppercase">
                            Chi tiết doanh thu ngày
                        </h2>

                        <p class="mt-0.5 text-xs text-gray-500">
                            Chi tiết từng ngày hoạt động
                        </p>
                    </div>

                    <span class="shrink-0 rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">
                        @salaryDetails.Count ca
                    </span>
                </div>

                @if (salaryDetails.Count == 0)
                {
                    <div class="p-8 text-center">
                        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gray-100">
                            <svg class="h-6 w-6 text-gray-400"
                                 fill="none"
                                 viewBox="0 0 24 24"
                                 stroke="currentColor">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M9 17v-2a4 4 0 014-4h4m0 0-3-3m3 3-3 3M5 5h7a2 2 0 012 2v1" />
                            </svg>
                        </div>

                        <p class="mt-3 text-sm font-medium text-gray-600">
                            Không có dữ liệu doanh thu
                        </p>
                    </div>
                }
                else
                {
                    <!-- Mobile -->
                    <div class="space-y-3 bg-gray-100 p-3 md:hidden">
                        @foreach (var item in salaryDetails)
                        {
                            <article class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                                <!-- Header từng ngày -->
                                <div class="flex items-center justify-between gap-3 border-b border-gray-100 bg-gray-50 px-4 py-3">
                                    <div class="min-w-0">
                                        <p class="font-semibold tracking-wide text-[10px] text-gray-400 uppercase">
                                            Ngày hoạt động
                                        </p>

                                        <a href="@($"/checker/{userId}/{FormatCheckerDateUrl(item.daterevenues)}")"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           class="mt-0.5 inline-flex items-center gap-1 text-base font-extrabold text-blue-600 hover:text-blue-800 hover:underline">
                                            @item.daterevenues

                                            <svg class="h-3.5 w-3.5 shrink-0"
                                                 fill="none"
                                                 viewBox="0 0 24 24"
                                                 stroke="currentColor">
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      stroke-width="2"
                                                      d="M14 3h7v7m0-7L10 14M5 7v12h12v-5" />
                                            </svg>
                                        </a>
                                    </div>

                                    <span class="shrink-0 rounded-full border border-gray-200 bg-white px-2.5 py-1 font-semibold text-[10px] text-gray-600">
                                        @(string.IsNullOrWhiteSpace(item.type)
                                                                    ? "Chưa xác định"
                                                                    : FormatSalaryType(item.type))
                        </span>
                    </div>

                                <!-- Nội dung từng ngày -->
                                <div class="p-3">
                                    <div class="grid gap-2 @(showSalaryBase ? "grid-cols-2" : "grid-cols-1")">
                                        <div class="min-w-0 rounded-lg border border-green-100 bg-green-50 px-3 py-3">
                                            <p class="font-semibold text-[10px] text-green-600 uppercase">
                                                Doanh thu
                                            </p>

                                            <p class="mt-1 text-base leading-tight font-extrabold text-green-700">
                                                @item.revenue.ltvVNDCurrency()
                                            </p>
                                        </div>

                            @if (showSalaryBase)
                                        {
                                            <div class="min-w-0 rounded-lg border border-blue-100 bg-blue-50 px-3 py-3">
                                                <p class="font-semibold text-[10px] text-blue-600 uppercase">
                                                    Sau mức ăn chia
                                                </p>

                                                <p class="mt-1 text-base leading-tight font-extrabold text-blue-700">
                                                    @item.salaryBase.ltvVNDCurrency()
                                                </p>
                                            </div>
                                        }
                                    </div>

                                    @if (showDriver)
                                    {
                                        <div class="mt-2 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2.5">
                                            <p class="font-semibold text-[10px] text-gray-400 uppercase">
                                                Người lái
                                            </p>

                                            <p class="mt-0.5 truncate text-sm font-semibold text-gray-800"
                                               title="@item.userId">
                                                @(string.IsNullOrWhiteSpace(item.userId)
                                                                                ? "Chưa xác định"
                                                                                : item.userId)
                            </p>
                        </div>
                                                }
                                </div>
                            </article>
                        }
                    </div>

                    <!-- Tablet và Desktop -->
                    <div class="hidden overflow-x-auto md:block">
                        <table class="w-full table-auto border-collapse">
                            <thead class="border-y border-gray-200 bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-semibold tracking-wide whitespace-nowrap text-gray-600 uppercase">
                                        Ngày
                                    </th>

                                    <th class="px-4 py-3 text-right text-xs font-semibold tracking-wide whitespace-nowrap text-gray-600 uppercase">
                                        Doanh thu
                                    </th>

                                    @if (showSalaryBase)
                                    {
                                        <th class="px-4 py-3 text-right text-xs font-semibold tracking-wide whitespace-nowrap text-gray-600 uppercase">
                                            Sau mức ăn chia
                                        </th>
                                    }

                                    @if (showDriver)
                                    {
                                        <th class="px-4 py-3 text-left text-xs font-semibold tracking-wide text-gray-600 uppercase">
                                            Người lái
                                        </th>
                                    }

                                    <th class="px-4 py-3 text-center text-xs font-semibold tracking-wide whitespace-nowrap text-gray-600 uppercase">
                                        Loại lương
                                    </th>
                                </tr>
                            </thead>

                            <tbody class="divide-y divide-gray-100 bg-white">
                                @foreach (var item in salaryDetails)
                                {
                                    <tr class="transition-colors hover:bg-gray-50">
                                        <td class="px-4 py-3 text-sm whitespace-nowrap">
                                            <a href="@($"/checker/{userId}/{FormatCheckerDateUrl(item.daterevenues)}")"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               class="font-semibold text-blue-600 hover:text-blue-800 hover:underline">
                                                @item.daterevenues
                                            </a>
                                        </td>

                                        <td class="px-4 py-3 text-right text-sm font-bold whitespace-nowrap text-green-700">
                                            @item.revenue.ltvVNDCurrency()
                                        </td>

                                        @if (showSalaryBase)
                                        {
                                            <td class="px-4 py-3 text-right text-sm font-bold whitespace-nowrap text-blue-700">
                                                @item.salaryBase.ltvVNDCurrency()
                                            </td>
                                        }

                                        @if (showDriver)
                                        {
                                            <td class="max-w-[260px] px-4 py-3 text-sm text-gray-700">
                                                <span class="block truncate"
                                                      title="@item.userId">
                                                    @(string.IsNullOrWhiteSpace(item.userId)
                                                                                        ? "—"
                                                                                        : item.userId)
                                </span>
                            </td>
                                                        }

                                    <td class="px-4 py-3 text-center text-sm whitespace-nowrap">
                                        <span class="inline-flex items-center justify-center rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600">
                                            @(string.IsNullOrWhiteSpace(item.type)
                                                                                ? "—"
                                                                                : FormatSalaryType(item.type))
                                </span>
                            </td>
                        </tr>
                                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            @if (!string.IsNullOrWhiteSpace(salary.noteDeductOrder))
            {
                <section class="rounded-xl border border-amber-200 bg-amber-50 p-4 shadow-sm">
                    <p class="text-xs font-bold tracking-wide text-amber-700 uppercase">Ghi chú</p>
                    <p class="mt-1 text-sm text-amber-900">@salary.noteDeductOrder</p>
                </section>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string userId { get; set; } = string.Empty;
    [Parameter] public string? date { get; set; }

    [Inject] protected ISalaryService salaryService { get; set; } = default!;

    protected SalaryResponse salary { get; set; } = new();
    protected SalaryResponseDto checkerSalary { get; set; } = new();
    protected List<SalaryDetails> salaryDetails { get; set; } = new();
    protected List<SalaryDeductDetailResponse> deductDetails { get; set; } = new();

    protected string errorMessage { get; set; } = string.Empty;
    protected bool isLoaded;
    protected string keyword { get; set; } = string.Empty;

    private static DateTime VnNow => DateTime.UtcNow.AddHours(7);
    private string maxMonthAllowed => VnNow.AddMonths(-1).ToString("yyyy-MM");
    private string currentMonthValue => ParseMonth(date).ToString("yyyy-MM");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Console.WriteLine($"Route userId nhận được: {userId}");
            if (string.IsNullOrWhiteSpace(userId))
                throw new Exception("Không tìm thấy userId trên đường dẫn.");
            var decryptedUserId =
                CryptographyAESExtension.Decrypt(userId);
            Console.WriteLine($"UserId sau giải mã: {decryptedUserId}");
            keyword = SearchNormalizer.Normalize(decryptedUserId);

            if (string.IsNullOrWhiteSpace(date))
                date = VnNow.AddMonths(-1).ToString("yyyy-MM");


            checkerSalary = await salaryService.GetSalaryByUser(userId, currentMonthValue);

            salary = checkerSalary.Salary ?? new SalaryResponse();
            salaryDetails = checkerSalary.Details?
                .OrderBy(x => ParseDetailDate(x.daterevenues))
                .ToList() ?? new List<SalaryDetails>();

            deductDetails = checkerSalary.DeductDetails?
                .Where(x => x.Amount != 0)
                .OrderBy(x => x.DeductCategoryId)
                .ThenBy(x => x.Name)
                .ToList() ?? new List<SalaryDeductDetailResponse>();

            showSalaryBase = ShouldShowSalaryBase();
            showDriver = ShouldShowDriver();

            isLoaded = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"CheckerSalary error: {errorMessage}");
            isLoaded = false;
        }
    }

    #region salaryType: Lương tháng, Lương ngày, TQ Góp Ngày, TQ Góp Tháng
    private bool showSalaryBase;
    private bool showDriver;

    private string CurrentSalaryType =>
        salary.salaryType?.Trim() ?? string.Empty;

    /// <summary>
    /// Hiển thị cột "Sau mức ăn chia":
    /// - Lương ngày
    /// - Thương quyền Góp Ngày
    /// </summary>
    private bool ShouldShowSalaryBase()
    {
        return string.Equals(
                   CurrentSalaryType,
                   "Lương ngày",
                   StringComparison.OrdinalIgnoreCase)
               ||
               string.Equals(
                   CurrentSalaryType,
                   "Thương quyền Góp Ngày",
                   StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Hiển thị cột "Người lái":
    /// - Thương quyền Góp Ngày
    /// - Thương quyền Góp Tháng
    /// </summary>
    private bool ShouldShowDriver()
    {
        return string.Equals(
                   CurrentSalaryType,
                   "Thương quyền Góp Ngày",
                   StringComparison.OrdinalIgnoreCase)
               ||
               string.Equals(
                   CurrentSalaryType,
                   "Thương quyền Góp Tháng",
                   StringComparison.OrdinalIgnoreCase);
    }

    private bool IsMonthlySalary()
    {
        return string.Equals(
            CurrentSalaryType,
            "Lương tháng",
            StringComparison.OrdinalIgnoreCase);
    }

    private bool IsDailySalary()
    {
        return string.Equals(
            CurrentSalaryType,
            "Lương ngày",
            StringComparison.OrdinalIgnoreCase);
    }

    private bool IsTQGOPSalary()
    {
        return ShouldShowDriver();
    }


    private static string FormatSalaryType(string? salaryType)
    {
        var value = salaryType?.Trim();

        if (string.IsNullOrWhiteSpace(value))
            return "Chưa xác định";

        if (value.Equals(
            "Lương tháng",
            StringComparison.OrdinalIgnoreCase))
        {
            return "Ăn chia tháng";
        }

        if (value.Equals(
            "Lương ngày",
            StringComparison.OrdinalIgnoreCase))
        {
            return "Ăn chia ngày";
        }

        if (value.Equals(
            "Thương quyền góp ngày",
            StringComparison.OrdinalIgnoreCase))
        {
            return "Góp ngày";
        }

        if (value.Equals(
            "Thương quyền góp tháng",
            StringComparison.OrdinalIgnoreCase))
        {
            return "Góp tháng";
        }

        return value;
    }

    #endregion

    private DateTime ParseMonth(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return VnNow.AddMonths(-1);

        var formats = new[] { "yyyy-MM", "MM-yyyy", "MM/yyyy" };

        if (DateTime.TryParseExact(
                value,
                formats,
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None,
                out var result))
        {
            return result;
        }

        return VnNow.AddMonths(-1);
    }

    private static DateTime ParseDetailDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return DateTime.MaxValue;

        var formats = new[]
        {
            "dd/MM/yyyy",
            "d/M/yyyy",
            "yyyy-MM-dd",
            "MM/dd/yyyy"
        };

        return DateTime.TryParseExact(
            value,
            formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None,
            out var result)
                ? result
                : DateTime.MaxValue;
    }

    private string displayMonth
    {
        get
        {
            if (string.IsNullOrWhiteSpace(currentMonthValue))
                return "Tháng/Năm";

            if (DateTime.TryParseExact(
                currentMonthValue,
                "yyyy-MM",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None,
                out var parsed))
            {
                return parsed.ToString("MM/yyyy");
            }

            return "Tháng/Năm";
        }
    }

    private static string FormatCheckerDateUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var formats = new[]
        {
        "dd/MM/yyyy",
        "d/M/yyyy",
        "yyyy-MM-dd",
        "MM/dd/yyyy"
    };

        return DateTime.TryParseExact(
            value,
            formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None,
            out var parsedDate)
                ? parsedDate.ToString("yyyy-MM-dd")
                : string.Empty;
    }
}
