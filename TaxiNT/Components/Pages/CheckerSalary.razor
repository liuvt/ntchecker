@page "/salary/{userId}"
@page "/salary/{userId}/{date}"
@inject NavigationManager NavigationManager
@layout EmptyMainLayout

<SeoHeaderComponent Title="Bảng kê v1.2"
                    Description="@($"Bảng kê tài xế {keyword}. Tháng {date}")" Ads="false" />

<script>
    function changeSalaryMonth(selectedMonth) {
        if (!selectedMonth) return;

        const userId = '@Uri.EscapeDataString(userId ?? string.Empty)';

        window.location.href = `/salary/${userId}/${selectedMonth}`;
    }
</script>

<div class="mx-auto max-w-4xl bg-gray-50 px-3 py-6">
    <div class="mb-6 text-center">
        <div class="flex items-center justify-center gap-3">
            <svg class="h-8 w-8 text-green-600"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor">
                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z" />
            </svg>

            <h1 class="text-2xl font-extrabold text-green-700 uppercase">
                Bảng kê
            </h1>
        </div>

        <div class="relative z-10 mt-2 inline-flex h-8 w-[110px] items-center justify-center gap-2 overflow-hidden rounded-full border border-red-100 bg-red-50 px-3 shadow-sm">
            <span class="pointer-events-none text-sm font-bold whitespace-nowrap text-red-500">
                @displayMonth
            </span>
            <input id="monthPicker"
                   type="month"
                   cursor="handle"
                   value="@currentMonthValue"
                   max="@maxMonthAllowed"
                   class="absolute inset-0 z-10 h-full w-full cursor-pointer opacity-0"
                   onchange="changeSalaryMonth(this.value)" />

            <span class="pointer-events-none text-sm">📅</span>

        </div>
    </div>

    @if (!isLoaded && string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-xl border border-gray-200 bg-white p-8 text-center shadow-sm">
            <div class="mx-auto h-8 w-8 animate-spin rounded-full border-4 border-gray-200 border-t-green-600"></div>
            <p class="mt-3 text-sm text-gray-500">Đang tải Bảng kê...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="rounded-xl border border-red-200 bg-red-50 p-5 text-center shadow-sm">
            <p class="font-semibold text-red-700">Không thể tải Bảng kê</p>
            <p class="mt-1 text-sm text-red-600">@errorMessage</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            <!-- Thông tin tổng quan -->
            <section class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="border-b border-green-100 bg-green-50 px-4 py-3">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">Mã tài xế</p>
                            <p class="text-lg font-extrabold text-green-700">@salary.userId</p>
                        </div>

                        <div class="rounded-lg border border-green-200 bg-white px-3 py-2 text-right">
                            <p class="text-xs text-gray-500">Khu vực</p>
                            <p class="font-semibold text-gray-800">@(string.IsNullOrWhiteSpace(salary.area) ? "—" : salary.area)</p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-px bg-gray-200 sm:grid-cols-4">
                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Tổng doanh thu</p>
                        <p class="mt-1 font-bold text-green-700">@salary.revenue.ltvVNDCurrency()</p>
                    </div>

                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Tổng số ca</p>
                        <p class="mt-1 font-bold text-gray-800">@salary.businessDays</p>
                    </div>

                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Số cuốc</p>
                        <p class="mt-1 font-bold text-gray-800">@salary.tripsTotal</p>
                    </div>

                    <div class="bg-white p-4">
                        <p class="text-xs text-gray-500 uppercase">Hình thức</p>
                        <p class="mt-1 font-bold text-gray-800">@FormatSalaryType(salary.salaryType)</p>
                    </div>
                </div>
            </section>

            <!-- Tổng hợp lương -->
            <section class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="border-b border-gray-200 px-4 py-3">
                    <h2 class="font-bold text-gray-800 uppercase">Tổng hợp bảng kê</h2>
                </div>

                <div class="divide-y divide-gray-100">
                    <div class="flex items-center justify-between gap-4 px-4 py-4">
                        <div>
                            <p class="font-semibold text-green-700">Tạm tính</p>
                            <p class="text-xs text-gray-500 italic">Ăn chia cơ bản hoặc số tiền sau mức ăn chia</p>
                        </div>
                        <p class="text-right font-bold whitespace-nowrap text-green-700">@salary.salaryBase.ltvVNDCurrency()</p>
                    </div>

                    @if (deductDetails.Count > 0)
                    {
                        @foreach (var item in deductDetails.Where(x => x.Amount != 0))
                        {
                            <div class="flex items-start justify-between gap-4 px-4 py-3">
                                <div class="min-w-0">
                                    <p class="font-medium text-gray-700">@item.Name <span class="text-red-500">(-)</span></p>

                                    @if (!string.IsNullOrWhiteSpace(item.Note))
                                    {
                                        <p class="mt-0.5 text-xs text-gray-500 italic">@item.Note</p>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(item.Code))
                                    {
                                        <p class="mt-0.5 text-xs text-gray-400 italic">@item.Code</p>
                                    }
                                </div>

                                <p class="text-right font-medium whitespace-nowrap text-gray-800">@item.Amount.ltvVNDCurrency()</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="px-4 py-4 text-center text-sm text-gray-500">
                            Không có khoản trừ.
                        </div>
                    }

                    <div class="flex items-center justify-between gap-4 bg-red-50 px-4 py-4">
                        <p class="font-bold text-red-600 uppercase">Tổng trừ</p>
                        <p class="text-right font-bold whitespace-nowrap text-red-600">@salary.deductTotal.ltvVNDCurrency()</p>
                    </div>

                    <div class="flex items-center justify-between gap-4 bg-green-50 px-4 py-5">
                        <div>
                            <p class="text-lg font-extrabold text-green-700 uppercase">Thực nhận</p>
                            <p class="text-xs text-green-600">Số tiền sau khi trừ các khoản phát sinh</p>
                        </div>
                        <p class="text-xl font-extrabold whitespace-nowrap text-green-700">@salary.salaryNet.ltvVNDCurrency()</p>
                    </div>
                </div>
            </section>

            <!-- Chi tiết doanh thu -->
            <section class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="flex flex-wrap items-center justify-between gap-2 border-b border-gray-200 px-4 py-3">
                    <div>
                        <h2 class="font-bold text-gray-800 uppercase">Chi tiết doanh thu ngày</h2>
                        <p class="text-xs text-gray-500">@FormatSalaryType(salary.salaryType)</p>
                    </div>
                    <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600">
                        @salaryDetails.Count dòng
                    </span>
                </div>

                @if (salaryDetails.Count == 0)
                {
                    <div class="p-6 text-center text-sm text-gray-500">
                        Không có dữ liệu chi tiết doanh thu.
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-semibold tracking-wide text-gray-600 uppercase">Ngày</th>
                                    <th class="px-4 py-3 text-right text-xs font-semibold tracking-wide text-gray-600 uppercase">Doanh thu</th>

                                    @if (!IsMonthlySalary())
                                    {
                                        <th class="px-4 py-3 text-right text-xs font-semibold tracking-wide text-gray-600 uppercase">Sau ăn chia</th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 bg-white">
                                @foreach (var item in salaryDetails)
                                {
                                    <tr class="hover:bg-gray-50">
                                        <td class="px-4 py-3 text-sm whitespace-nowrap">
                                            <a href="@($"/checker/{userId}/{FormatCheckerDateUrl(item.daterevenues)}")"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               class="font-medium text-blue-600 hover:text-blue-800 hover:underline">
                                                @item.daterevenues
                                            </a>
                                        </td>
                                        <td class="px-4 py-3 text-right text-sm font-medium whitespace-nowrap text-green-700">@item.revenue.ltvVNDCurrency()</td>

                                        @if (!IsMonthlySalary())
                                        {
                                            <td class="px-4 py-3 text-right text-sm font-medium whitespace-nowrap text-green-700">@item.salaryBase.ltvVNDCurrency()</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            @if (!string.IsNullOrWhiteSpace(salary.noteDeductOrder))
            {
                <section class="rounded-xl border border-amber-200 bg-amber-50 p-4 shadow-sm">
                    <p class="text-xs font-bold tracking-wide text-amber-700 uppercase">Ghi chú</p>
                    <p class="mt-1 text-sm text-amber-900">@salary.noteDeductOrder</p>
                </section>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string userId { get; set; } = string.Empty;
    [Parameter] public string? date { get; set; }

    [Inject] protected ISalaryService salaryService { get; set; } = default!;

    protected SalaryResponse salary { get; set; } = new();
    protected SalaryResponseDto checkerSalary { get; set; } = new();
    protected List<SalaryDetails> salaryDetails { get; set; } = new();
    protected List<SalaryDeductDetailResponse> deductDetails { get; set; } = new();

    protected string errorMessage { get; set; } = string.Empty;
    protected bool isLoaded;
    protected string keyword { get; set; } = string.Empty;

    private static DateTime VnNow => DateTime.UtcNow.AddHours(7);
    private string maxMonthAllowed => VnNow.AddMonths(-1).ToString("yyyy-MM");
    private string currentMonthValue => ParseMonth(date).ToString("yyyy-MM");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Console.WriteLine($"Route userId nhận được: {userId}");
            if (string.IsNullOrWhiteSpace(userId))
                throw new Exception("Không tìm thấy userId trên đường dẫn.");
            var decryptedUserId =
                CryptographyAESExtension.Decrypt(userId);
            Console.WriteLine($"UserId sau giải mã: {decryptedUserId}");
            keyword = SearchNormalizer.Normalize(decryptedUserId);

            if (string.IsNullOrWhiteSpace(date))
                date = VnNow.AddMonths(-1).ToString("yyyy-MM");


            checkerSalary = await salaryService.GetSalaryByUser(userId, currentMonthValue);

            salary = checkerSalary.Salary ?? new SalaryResponse();
            salaryDetails = checkerSalary.Details?
                .OrderBy(x => ParseDetailDate(x.daterevenues))
                .ToList() ?? new List<SalaryDetails>();

            deductDetails = checkerSalary.DeductDetails?
                .Where(x => x.Amount != 0)
                .OrderBy(x => x.DeductCategoryId)
                .ThenBy(x => x.Name)
                .ToList() ?? new List<SalaryDeductDetailResponse>();

            isLoaded = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"CheckerSalary error: {errorMessage}");
            isLoaded = false;
        }
    }

    private bool IsMonthlySalary()
    {
        return string.Equals(
            salary.salaryType?.Trim(),
            "Lương tháng",
            StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatSalaryType(string? salaryType)
    {
        if (string.IsNullOrWhiteSpace(salaryType))
            return "Chưa xác định";

        if (salaryType.Equals("Lương tháng", StringComparison.OrdinalIgnoreCase))
            return "Ăn chia tháng";

        if (salaryType.Equals("Lương ngày", StringComparison.OrdinalIgnoreCase))
            return "Ăn chia ngày";

        return salaryType;
    }

    private DateTime ParseMonth(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return VnNow.AddMonths(-1);

        var formats = new[] { "yyyy-MM", "MM-yyyy", "MM/yyyy" };

        if (DateTime.TryParseExact(
                value,
                formats,
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None,
                out var result))
        {
            return result;
        }

        return VnNow.AddMonths(-1);
    }

    private static DateTime ParseDetailDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return DateTime.MaxValue;

        var formats = new[]
        {
            "dd/MM/yyyy",
            "d/M/yyyy",
            "yyyy-MM-dd",
            "MM/dd/yyyy"
        };

        return DateTime.TryParseExact(
            value,
            formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None,
            out var result)
                ? result
                : DateTime.MaxValue;
    }

    private string displayMonth
    {
        get
        {
            if (string.IsNullOrWhiteSpace(currentMonthValue))
                return "Tháng/Năm";

            if (DateTime.TryParseExact(
                currentMonthValue,
                "yyyy-MM",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None,
                out var parsed))
            {
                return parsed.ToString("MM/yyyy");
            }

            return "Tháng/Năm";
        }
    }

    private static string FormatCheckerDateUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var formats = new[]
        {
        "dd/MM/yyyy",
        "d/M/yyyy",
        "yyyy-MM-dd",
        "MM/dd/yyyy"
    };

        return DateTime.TryParseExact(
            value,
            formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None,
            out var parsedDate)
                ? parsedDate.ToString("yyyy-MM-dd")
                : string.Empty;
    }
}
